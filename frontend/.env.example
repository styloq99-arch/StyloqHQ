# ═══════════════════════════════════════════════════════════════════════════════
# ENVIRONMENT CONFIGURATION TEMPLATE
# ═══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to your project root as .env
# Location: d:\IIT 2nd Year\SDGP\StyloqHQ\frontend\.env
#
# The barberApi.js service will automatically use VITE_API_BASE_URL
# If not set, it defaults to http://localhost:5000

# ─────────────────────────────────────────────────────────────────────────────
# API BASE URL
# ─────────────────────────────────────────────────────────────────────────────
# 
# For local development (backend running locally):
VITE_API_BASE_URL=http://localhost:5000

# For production:
# VITE_API_BASE_URL=https://api.styloq.com

# For staging:
# VITE_API_BASE_URL=https://staging-api.styloq.com


# ─────────────────────────────────────────────────────────────────────────────
# DEBUG MODE (optional)
# ─────────────────────────────────────────────────────────────────────────────
# 
# Uncomment to enable debug logging in browser console:
# VITE_DEBUG=true


# ─────────────────────────────────────────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Make sure backend is running on port 5000 during development
#    Or update VITE_API_BASE_URL to match your backend port
#
# 2. In barberApi.js, the BASE_URL is constructed as:
#    const API_BASE_URL = import.meta.env.VITE_API_BASE_URL || "http://localhost:5000";
#
# 3. The BARBER_ENDPOINT will be:
#    ${API_BASE_URL}/barber
#
# 4. Full example endpoints:
#    - GET http://localhost:5000/barber/123/profile
#    - PUT http://localhost:5000/barber/123/profile
#    - POST http://localhost:5000/barber/123/book
#
# 5. All requests will automatically include token from localStorage
#    Authorization: Bearer <token>
#
# 6. Don't commit actual API keys or tokens to git
#    Add .env to .gitignore (should already be there)
